# ── Aegis Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# Variables can also be set via the setup wizard (aegis setup).

# ── AI Provider API Keys ─────────────────────────────────────────────
# At least one AI provider API key is required for agent/chat functionality.

# Anthropic (Claude models)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT / o-series models)
OPENAI_API_KEY=sk-...

# DeepSeek (Chat / Reasoner models)
DEEPSEEK_API_KEY=sk-...

# ── AI Provider Configuration ────────────────────────────────────────

# Default provider to use when no provider is specified.
# Supported: anthropic, openai, deepseek, ollama, custom
AEGIS_DEFAULT_PROVIDER=anthropic

# Default model to use (overridden by provider-specific defaults)
AEGIS_DEFAULT_MODEL=claude-sonnet-4-20250514

# Agent AI configuration (used by agent-worker.ts for ReAct loops)
AEGIS_AI_PROVIDER=anthropic
AEGIS_AI_MODEL=claude-sonnet-4-20250514
AEGIS_AI_API_KEY=sk-ant-...
AEGIS_AI_BASE_URL=

# Agent limits
AEGIS_MAX_TURNS=20
AEGIS_TEMPERATURE=0.7
AEGIS_MAX_TOKENS=

# ── Ollama (Local Models) ─────────────────────────────────────────────
# No API key needed for Ollama. Set OLLAMA_URL if using a non-default host.
OLLAMA_URL=http://localhost:11434

# ── Web Search ────────────────────────────────────────────────────────
# Web search uses DuckDuckGo by default (no API key needed).
# For better results, set a Tavily or SerpAPI API key:
# TAVILY_API_KEY=tvly-...
# SERPAPI_API_KEY=...

# ── Credential Vault ─────────────────────────────────────────────────
# Optional: Set your own encryption key for the credential vault.
# If not set, a key is auto-generated and stored at ~/.aegis/.vault-key.
# Must be a 64-character hex string (32 bytes / 256 bits).
# AEGIS_VAULT_KEY=<64-hex-chars>

# ── API Server ────────────────────────────────────────────────────────
# Configure the HTTP API server (aegis serve)

# Port for the API server (default: 8080)
# AEGIS_API_PORT=8080

# Allowed CORS origins (comma-separated, default: http://localhost:5173)
# AEGIS_API_CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# API key for authenticating API requests (optional)
# AEGIS_API_KEY=your-api-key

# Rate limiting (requests per minute per IP, default: 100)
# AEGIS_RATE_LIMIT_MAX=100

# ── AgentMemory Sidecar ───────────────────────────────────────────────
# Optional: Connect to an agentmemory sidecar for enhanced search.

# AGENTMEMORY_URL=http://localhost:3111
# AGENTMEMORY_SECRET=your-secret-token
# AGENTMEMORY_ENABLED=false

# ── Telemetry ─────────────────────────────────────────────────────────
# Opt-in usage telemetry to help improve Aegis.
# No PII is collected — only command names, duration, and success/failure.
# AEGIS_TELEMETRY=1

# Telemetry ingestion endpoint (default: https://telemetry.aegis.sh/v1/event)
# AEGIS_TELEMETRY_ENDPOINT=https://telemetry.aegis.sh/v1/event

# ── Logging ───────────────────────────────────────────────────────────
# Log level: debug, info, warn, error (default: info)
AEGIS_LOG_LEVEL=info

# Optional: Write logs to a file (rotated at 10MB, up to 5 files)
# AEGIS_LOG_FILE=/path/to/aegis.log

# ── Docker ────────────────────────────────────────────────────────────
# These are used by the Docker container, not local development.
# HEALTHCHECK --interval=30s --timeout=10s --retries=3

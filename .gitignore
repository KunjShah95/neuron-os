# dependencies (bun install)
node_modules

# output
out
dist
*.tgz

# code coverage
coverage
*.lcov

# logs
logs
*.log
report.[0-9]_.[0-9]_.[0-9]_.[0-9]_.json

# dotenv environment variable files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# caches
.eslintcache
.cache
*.tsbuildinfo

# IntelliJ based IDEs
.idea

# Finder (MacOS) folder config
.DS_Store

# Local profile containing API keys - do not commit
.openclaude-profile.json

# Ignore persisted session data (local only)
data/sessions/

# Ignore runtime-mutated data files
data/triggers.json
data/cron-jobs.json
data/HEARTBEAT.md
data/vault/

# SQLite databases (runtime state — auto-generated by bun:sqlite)
*.db
*.db-shm
*.db-wal
data/audit/
data/telemetry/
data/experience/

# Ignore leftover test temp directories
tmp-*

# Evolution engine backup artifacts (auto-generated during code-mutator runs)
data/evolve/backups/

# Ignore Qodo / AI agent config artifacts
.qodo/

# Local superpowers / aegis runtime state
.aegis/
.superpowers/
.commandcode/

# Git worktrees (never commit the worktree directory itself)
.worktrees/

# Windows junk / accidental redirections
nul
C:*

# Generated signed plugin manifests
*.signed.json

# Demo / temp artifacts
demo-video/
tmp/

# Top-level planning artifacts (one-time, not source)
task.md
implementation_plan.md
copy-site.js

# Test stubs / example utils (not real source)
src/utils/doSomething.ts
src/utils/greet.ts
src/utils/hello.ts

# Ignore docs (design specs, plans, etc.)
docs/

# Ignore all Markdown files except essential project docs
*.md
!/README.md
!/ROADMAP.md
!/COMMANDS.md
!/CHANGELOG.md
!/CONTRIBUTING.md
!/SECURITY.md
!/security-whitepaper.md
